{
    "manifest_version": 3,
    "name": "Auto Timer Click Streaming Community",
    "version": "1.0.0",
    "description": "Monitora un timer e clicca automaticamente un bottone per demo su webapp.",
    "permissions": ["storage", "tabs"],
    "host_permissions": ["<all_urls>"],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Auto Timer Click Demo"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_idle",
            "all_frames": true
        }
    ]
}
